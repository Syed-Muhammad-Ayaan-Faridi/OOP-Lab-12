import java.util.*;

class Generic {

    public static <T extends Comparable<T>> void sortList(List<T> list) {
        Collections.sort(list);
    }

    public static double sumList(List<? extends Number> list) {
        double sum = 0;
        for (Number num : list) {
            sum += num.doubleValue();
        }
        return sum;
    }

    public static <T extends Comparable<T>> T maxValue(List<T> list) {
        return Collections.max(list);
    }

    public static void printList(List<?> list) {
        for (Object obj : list) {
            System.out.print(obj + " ");
        }
        System.out.println();
    }
}

// Main class
public class Task3 {
    public static void main(String[] args) {

        List<Number> list = new ArrayList<>();
        list.add(10);       
        list.add(5.5);      
        list.add(20);       
        list.add(3.3);      

        list.sort((a, b) -> Double.compare(a.doubleValue(), b.doubleValue()));

        System.out.print("Sorted List: ");
        Generic.printList(list);

        double sum = Generic.sumList(list);
        System.out.println("Sum: " + sum);

        Number max = Collections.max(list, (a, b) ->
                Double.compare(a.doubleValue(), b.doubleValue()));
        System.out.println("Maximum Value: " + max);
    }
}
