import java.util.Scanner;

class Login<T,U>{
    private T username;
    private U password;

    Login(T username, U password){
        this.username = username;
        this.password = password;
    }

    public boolean CheckPassword(T usernameEntered, U passwordEntered){
        if (this.username.equals(usernameEntered) && this.password.equals(passwordEntered)) {
            System.out.println("Login Successful");
            return true;
        } else{
            return false;
        }
    }
}
public class Task1 {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Login<String, String> storedUser = new Login<>("admin", "12345");
        System.out.print("Enter username: ");
        String inputUser = scanner.nextLine();
        System.out.print("Enter password: ");
        String inputPass = scanner.nextLine();
        // Validation
        if (storedUser.CheckPassword(inputUser, inputPass)) {
            System.out.println("Login successful! Welcome.");
        } else {
            System.out.println("Invalid username or password. Program terminated.");
            System.exit(0);
        }
    }
}
